{
  "name": "ngx-signal-query",
  "version": "0.0.0",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve playground",
    "docs:start": "ng serve docs",
    "docs:build": "ng build docs",
    "docs:build:gh": "ng build docs --base-href=/ngx-signal-query/",
    "build:lib": "ng build ngx-signal-query && cp README.md LICENSE dist/ngx-signal-query/",
