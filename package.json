    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@ng-doc/app": "20.2.0",
    "@ng-doc/builder": "20.2.0",
    "@ng-doc/core": "20.2.0",
    "@ng-doc/ui-kit": "20.2.0",
    "@ng-web-apis/common": "^4.0.0",
    "@tinkoff/ng-polymorpheus": "4.3.0",
    "di-controls": "2.1.0",
    "rxjs": "~7.8.0",
