    "test:ci": "ng test ngx-signal-query --watch=false --browsers=ChromeHeadless",
    "test:coverage": "ng test ngx-signal-query --watch=false --browsers=ChromeHeadless --code-coverage",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.0",
